# Backend API URL
# Simulator/emulator:  http://localhost:5000/api
# Physical device:     http://<YOUR_LOCAL_IP>:5000/api  (e.g. http://192.168.1.42:5000/api)
# Production:          https://api.yourdomain.com/api
EXPO_PUBLIC_API_URL=http://localhost:5000/api
