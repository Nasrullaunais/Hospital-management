<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Medical Certificate - {{hospitalName}}</title>
<style>
  @page { size: A4; margin: 0; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    color: #2c3e50;
    font-size: 11px;
    line-height: 1.6;
    background: #fff;
  }
  .page {
    width: 210mm;
    min-height: 297mm;
    padding: 22mm 20mm 16mm;
    position: relative;
  }

  /* ── WATERMARK ── */
  .watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.02;
    pointer-events: none;
    z-index: 0;
  }
  .watermark svg {
    width: 320px;
    height: 320px;
  }

  /* ── TOP DECORATIVE BORDER ── */
  .top-border {
    height: 5px;
    background: linear-gradient(to right, #1a5276, #2980b9, #1a5276);
    border-radius: 3px;
    margin-bottom: 14px;
  }

  /* ── HEADER / LETTERHEAD ── */
  .letterhead {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    border-bottom: 2px solid #1a5276;
    padding-bottom: 12px;
    margin-bottom: 18px;
  }
  .lh-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .lh-left svg {
    width: 44px;
    height: 44px;
  }
  .lh-hospital {
    line-height: 1.3;
  }
  .lh-hospital .lh-name {
    font-size: 22px;
    font-weight: 700;
    color: #1a5276;
    letter-spacing: 1.5px;
  }
  .lh-hospital .lh-tagline {
    font-size: 9px;
    color: #7f8c8d;
    font-style: italic;
  }
  .lh-right {
    text-align: right;
    font-size: 9px;
    color: #5d6d7e;
    line-height: 1.7;
  }
  .lh-right .lh-contact-label {
    font-weight: 600;
    color: #1a5276;
    font-size: 8.5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* ── CERTIFICATE META ── */
  .cert-meta {
    display: flex;
    justify-content: flex-end;
    gap: 20px;
    margin-bottom: 12px;
    font-size: 9px;
    color: #5d6d7e;
  }
  .cert-meta strong {
    color: #1a5276;
  }

  /* ── TITLE ── */
  .cert-title-area {
    text-align: center;
    margin-bottom: 22px;
  }
  .cert-title-area .cert-icon {
    font-size: 28px;
    color: #1a5276;
    margin-bottom: 2px;
  }
  .cert-title-area h1 {
    font-family: 'Georgia', 'Times New Roman', Times, serif;
    font-size: 24px;
    font-weight: 700;
    color: #1a5276;
    letter-spacing: 4px;
    text-transform: uppercase;
    border-bottom: 1px solid #dee2e6;
    display: inline-block;
    padding: 0 20px 6px;
  }

  /* ── BODY ── */
  .cert-body {
    font-size: 11.5px;
    color: #2c3e50;
    margin-bottom: 18px;
    padding: 0 4px;
  }
  .cert-body p {
    margin-bottom: 10px;
    text-align: justify;
  }
  .cert-body .cert-highlight {
    font-weight: 600;
    color: #1a5276;
  }

  /* ── DIAGNOSIS ── */
  .cert-diagnosis {
    margin-bottom: 14px;
    padding: 8px 14px;
    background: #f0f4f8;
    border-left: 4px solid #2980b9;
    border-radius: 2px;
    font-size: 11px;
  }
  .cert-diagnosis .cd-label {
    font-weight: 700;
    color: #1a5276;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .cert-diagnosis .cd-value {
    font-weight: 600;
    color: #2c3e50;
    margin-top: 2px;
  }

  /* ── REST PERIOD ── */
  .cert-rest {
    margin-bottom: 14px;
    padding: 8px 14px;
    background: #eafaf1;
    border-left: 4px solid #27ae60;
    border-radius: 2px;
    font-size: 11px;
  }
  .cert-rest .cr-label {
    font-weight: 700;
    color: #1e8449;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .cert-rest .cr-value {
    color: #2c3e50;
    margin-top: 2px;
  }

  /* ── FITNESS NOTE ── */
  .cert-fitness {
    margin-bottom: 20px;
    padding: 8px 14px;
    background: #fdfefe;
    border: 1px solid #dee2e6;
    border-radius: 3px;
    font-size: 10.5px;
  }
  .cert-fitness strong {
    color: #1a5276;
  }

  /* ── SIGNATURE ── */
  .signature-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-top: 28px;
    padding-top: 16px;
  }
  .sig-doctor {
    flex: 1;
  }
  .sig-line {
    width: 200px;
    border-bottom: 1px solid #2c3e50;
    margin-bottom: 4px;
    height: 32px;
  }
  .sig-name {
    font-weight: 600;
    font-size: 11px;
    color: #1a5276;
  }
  .sig-title {
    font-size: 10px;
    color: #5d6d7e;
  }
  .sig-reg {
    font-size: 8.5px;
    color: #7f8c8d;
    margin-top: 1px;
  }
  .sig-stamp-area {
    text-align: center;
    width: 110px;
  }
  .sig-stamp-area svg {
    width: 80px;
    height: 80px;
  }

  /* ── BOTTOM INFO ── */
  .cert-bottom {
    margin-top: 24px;
    padding-top: 10px;
    border-top: 1px solid #dee2e6;
    text-align: center;
    font-size: 9px;
    color: #7f8c8d;
  }
  .cert-bottom strong {
    color: #1a5276;
  }
  .cert-bottom .cert-disclaimer {
    font-size: 8px;
    color: #95a5a6;
    margin-top: 4px;
  }

  /* ── FOOTER ── */
  .footer {
    position: absolute;
    bottom: 12mm;
    left: 20mm;
    right: 20mm;
    text-align: center;
    font-size: 7.5px;
    color: #95a5a6;
    border-top: 1px solid #dee2e6;
    padding-top: 5px;
  }

  /* ── PAGE BREAK ── */
  .page-break { page-break-before: always; }

  @media print {
    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }
</style>
</head>
<body>
<div class="page">

  <!-- ── WATERMARK ── -->
  <div class="watermark">
    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <rect x="42" y="10" width="16" height="80" rx="4" fill="#1a5276"/>
      <rect x="10" y="42" width="80" height="16" rx="4" fill="#1a5276"/>
      <circle cx="50" cy="50" r="45" fill="none" stroke="#1a5276" stroke-width="2"/>
      <circle cx="50" cy="50" r="30" fill="none" stroke="#1a5276" stroke-width="1"/>
    </svg>
  </div>

  <!-- ── TOP DECORATIVE BORDER ── -->
  <div class="top-border"></div>

  <!-- ── LETTERHEAD ── -->
  <div class="letterhead">
    <div class="lh-left">
      <svg viewBox="0 0 44 44" xmlns="http://www.w3.org/2000/svg">
        <rect x="17" y="5" width="10" height="34" rx="2" fill="#1a5276"/>
        <rect x="5" y="17" width="34" height="10" rx="2" fill="#1a5276"/>
        <circle cx="22" cy="22" r="20" fill="none" stroke="#2980b9" stroke-width="1.5"/>
      </svg>
      <div class="lh-hospital">
        <div class="lh-name">{{hospitalName}}</div>
        <div class="lh-tagline">Compassionate Care &bull; Excellence Always</div>
      </div>
    </div>
    <div class="lh-right">
      <div class="lh-contact-label">Contact</div>
      {{hospitalAddress}}<br />
      {{hospitalPhone}}<br />
      info@lifelinecare.med
    </div>
  </div>

  <!-- ── CERTIFICATE META ── -->
  <div class="cert-meta">
    <span><strong>Certificate No:</strong> {{certificateId}}</span>
    <span><strong>Date:</strong> {{reportDate}}</span>
  </div>

  <!-- ── TITLE ── -->
  <div class="cert-title-area">
    <div class="cert-icon">&#9765;</div>
    <h1>Medical Certificate</h1>
  </div>

  <!-- ── BODY ── -->
  <div class="cert-body">
    <p>
      This is to certify that <span class="cert-highlight">{{patientName}}</span>,
      aged <span class="cert-highlight">{{patientAge}}</span> years,
      ID: <span class="cert-highlight">{{patientId}}</span>,
      was examined at <span class="cert-highlight">{{hospitalName}}</span>
      on <span class="cert-highlight">{{dateOfExamination}}</span>.
    </p>
  </div>

  <!-- ── DIAGNOSIS ── -->
  <div class="cert-diagnosis">
    <div class="cd-label">Diagnosis</div>
    <div class="cd-value">{{diagnosis}}</div>
  </div>

  <!-- ── REST PERIOD (conditional) ── -->
  {{#if restFrom}}
  <div class="cert-rest">
    <div class="cr-label">Recommended Rest Period</div>
    <div class="cr-value">
      The patient is advised to take rest from <strong>{{restFrom}}</strong> to <strong>{{restTo}}</strong>
      {{#if restDays}}(<strong>{{restDays}}</strong> day(s)){{/if}}.
    </div>
  </div>
  {{/if}}

  <!-- ── FITNESS NOTE ── -->
  <div class="cert-fitness">
    <strong>Medical Fitness:</strong>
    {{fitnessNote}}
  </div>

  <!-- ── SIGNATURE ── -->
  <div class="signature-row">
    <div class="sig-doctor">
      <div class="sig-line"></div>
      <div class="sig-name">{{doctorName}}</div>
      <div class="sig-title">{{doctorSpecialization}} &bull; {{hospitalName}}</div>
      <div class="sig-reg">Medical License: LIC-{{doctorSpecialization}}-{{certificateId}}</div>
    </div>
    <div class="sig-stamp-area">
      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
        <circle cx="40" cy="40" r="38" fill="none" stroke="#1a5276" stroke-width="1.2" opacity="0.35"/>
        <circle cx="40" cy="40" r="28" fill="none" stroke="#1a5276" stroke-width="0.8" opacity="0.25"/>
        <circle cx="40" cy="40" r="14" fill="none" stroke="#1a5276" stroke-width="2" opacity="0.2"/>
        <text x="40" y="43" text-anchor="middle" font-size="6" fill="#1a5276" opacity="0.4" font-family="'Segoe UI', sans-serif">HOSPITAL STAMP</text>
        <text x="40" y="52" text-anchor="middle" font-size="4" fill="#1a5276" opacity="0.3" font-family="'Segoe UI', sans-serif">&amp; SEAL</text>
      </svg>
    </div>
  </div>

  <!-- ── BOTTOM ── -->
  <div class="cert-bottom">
    <strong>Issued at:</strong> {{hospitalName}}, {{hospitalAddress}}<br />
    <div class="cert-disclaimer">
      This certificate is issued for medical purposes only and is not a legal document.
      Unauthorized reproduction or alteration is prohibited.
    </div>
  </div>

  <!-- ── FOOTER ── -->
  <div class="footer">
    Page 1 of 1 &bull; {{hospitalName}} &bull; {{hospitalPhone}}
  </div>

</div>
</body>
</html>
