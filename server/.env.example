# ── Server Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Environment mode
NODE_ENV=production

# Server port
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Docker Compose sets these — replace only if running outside Docker
MONGO_URI=mongodb://<MONGO_ROOT_USER>:<MONGO_ROOT_PASSWORD>@mongo:27017/hospital?authSource=admin

# ── Authentication ──────────────────────────────────────────────────────────
# JWT secret — use a strong random string (e.g. openssl rand -base64 32)
JWT_SECRET=<replace with a strong secret>

# JWT expiry — e.g. 7d, 24h, 60m
JWT_EXPIRES_IN=7d

# ── AWS S3 (optional, needed only if using file uploads) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# S3 object key prefix (namespace all project files)
AWS_S3_PREFIX=hospital-management/

# S3 presigned URL expiry (seconds)
S3_PRESIGNED_UPLOAD_EXPIRY=3600
S3_PRESIGNED_DOWNLOAD_EXPIRY=300
