# ─────────────────────────────────────────────────────────────
#  Hospital Management System — Server Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000

# MongoDB
# Local:   mongodb://localhost:27017/hospital-management
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/hospital-management
MONGO_URI=mongodb://localhost:27017/hospital-management

# JWT
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
#  Phase 6: AWS Configuration (Member 6 — Billing & Deployment)
#  Uncomment and fill in when setting up AWS deployment.
# ─────────────────────────────────────────────────────────────

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=hospital-management-uploads

# CORS — comma-separated list of allowed origins (production)
# CORS_ORIGINS=https://your-app-domain.com
