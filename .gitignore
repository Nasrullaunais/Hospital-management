# ────────────────────────────────────────────────────────────
#  Hospital Management System — Root .gitignore
# ────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Bun
bun.lockb

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment variables (NEVER commit secrets)
.env
.env.*
!.env.example

# File uploads (local dev storage)
server/uploads/

# Expo / React Native
.expo/
.expo-shared/
client/dist/

# iOS / Android builds
ios/
android/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V2
.Trashes
ehthumbs.db
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/settings.json
!.vscode/extensions.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# Testing
coverage/
.nyc_output/

# Misc
*.orig
*.bak
